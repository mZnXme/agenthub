NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:3000
ADMIN_EMAILS=admin@example.com
APP_ENCRYPTION_KEY=change-me-provider-key-encryption-secret

DATABASE_URL=postgresql://agenthub:agenthub@localhost:5432/agenthub?schema=public

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"

OPENCODE_URL=http://localhost:4096
OPENCODE_BIN=opencode
OPENCODE_SESSION_ROOT=/opencode-sessions
OPENCODE_SERVER_PASSWORD=

POSTGRES_DB=agenthub
POSTGRES_USER=agenthub
POSTGRES_PASSWORD=agenthub

MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=agenthub-local
STORAGE_FORCE_PATH_STYLE=true

SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
