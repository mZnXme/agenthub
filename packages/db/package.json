{
  "name": "@agenthub/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/generated/client/index.js",
  "types": "./src/generated/client/index.d.ts",
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma",
    "type-check": "prisma generate --schema=./prisma/schema.prisma && tsc --noEmit",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=./prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "@agenthub/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "prisma": "^6.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
