{
  "name": "agenthub",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "pnpm --filter @agenthub/db db:generate",
    "db:migrate": "pnpm --filter @agenthub/db db:migrate",
    "db:deploy": "pnpm --filter @agenthub/db db:deploy",
    "db:reset": "pnpm --filter @agenthub/db db:reset",
    "db:seed": "pnpm --filter @agenthub/db db:seed",
    "db:studio": "pnpm --filter @agenthub/db db:studio",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
